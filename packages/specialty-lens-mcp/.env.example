PORT=7860
NODE_ENV=development
LOG_LEVEL=info

# Gemini (free tier from AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Supabase — audit log
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Sentry — Node project DSN
SENTRY_DSN=
